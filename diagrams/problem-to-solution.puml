@startuml problem-to-solution
!theme plain
skinparam backgroundColor #FFFFFF
skinparam DefaultFontName Segoe UI
skinparam rectangle {
  FontColor #212121
  shadowing false
}
skinparam ArrowColor #455A64
skinparam ArrowFontColor #455A64

title <b>Mapping Business Problems to Frameworks and Recommendations</b>

package "Business Problems" #FFEBEE {
  rectangle "Overstocking and\nUnderstocking" as P1 #EF9A9A
  rectangle "Repeat Customer\nPatterns" as P2 #FFCC80
  rectangle "Marketing\nStrategies" as P3 #9FA8DA
}

package "Analytical Toolkit" #E8F5E9 {
  rectangle "EOQ" as F1 #A5D6A7
  rectangle "ROL" as F2 #A5D6A7
  rectangle "ABC Analysis" as F3 #A5D6A7
  rectangle "Pareto (80/20)" as F4 #A5D6A7
  rectangle "RFM Analysis" as F5 #A5D6A7
  rectangle "SWOT" as F6 #A5D6A7
  rectangle "Geo Mapping" as F7 #A5D6A7
}

package "Recommendations" #FFFDE7 {
  rectangle "Season-Based\nStock Planning" as R1 #FFF59D
  rectangle "Subscription &\nLoyalty Programs" as R2 #FFF59D
  rectangle "Regionally Targeted\nCampaigns" as R3 #FFF59D
  rectangle "Real-Time KPI\nDashboard" as R4 #FFF59D
}

P1 --> F1
P1 --> F2
P1 --> F3
P2 --> F5
P2 --> F6
P3 --> F4
P3 --> F7
P3 --> F6

F1 --> R1
F2 --> R1
F3 --> R1
F5 --> R2
F6 --> R3
F4 --> R3
F7 --> R3
F6 --> R4
F3 --> R4

@enduml
